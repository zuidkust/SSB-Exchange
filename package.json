    "test:sports:http": "node --disable-warning=ExperimentalWarning server/sports-http-test.js",
    "test:migration": "node --disable-warning=ExperimentalWarning server/db-migration-test.js",
    "test:calibration": "node --disable-warning=ExperimentalWarning server/calibration-test.js",
    "test:orderflow": "node --disable-warning=ExperimentalWarning server/order-flow-test.js",
    "test:messages": "node --disable-warning=ExperimentalWarning server/error-message-test.js",
